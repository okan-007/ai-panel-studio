# =============================================================================
# AI Panel Studio -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Required: Deepseek API Key (get one at https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-api-key-here

# Optional: Deepseek API configuration
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: Server configuration
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Optional: SQLite database path (relative to server root)
DB_PATH=./data/ai-panel.db
